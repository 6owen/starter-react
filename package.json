{
  "name": "starter-react",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier . --write --ignore-unknown",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview",
    "start": "vite preview",
    "setup-arvin": "pnpm up @arvinn/eslint-config @arvinn/prettier-config @arvinn/vscode-settings && npx arvinn-vscode-settings",
    "prepare": "simple-git-hooks",
    "format:check": "prettier . --check --ignore-unknown",
    "lint:fix": "eslint . --fix",
    "fix": "pnpm format && pnpm lint:fix",
    "up": "taze major -I"
  },
  "dependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@iconify-json/carbon": "^1.2.23",
    "@iconify-json/solar": "^1.2.5",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^6.30.4",
    "react-use": "^17.6.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@arvinn/eslint-config": "^0.0.15",
    "@arvinn/prettier-config": "^0.0.13",
    "@arvinn/vscode-settings": "^0.0.3",
    "@eslint/js": "^10",
    "@tailwindcss/vite": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "taze": "^19.14.1",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8",
    "vite-plugin-pages": "^0.33.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "prettier": "@arvinn/prettier-config",
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged || true"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,cjs}": "eslint --fix --no-warn-ignored",
    "**/*.{css,md,json}": "prettier --write --ignore-unknown"
  }
}
