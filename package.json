{
  "name": "vite-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "start:web": "pnpm --filter web start",
    "setup-arvin": "pnpm up @arvinn/eslint-config @arvinn/prettier-config @arvinn/vscode-settings && npx arvinn-vscode-settings",
    "prepare": "simple-git-hooks",
    "format:check": "prettier . --check --ignore-unknown",
    "lint:fix": "turbo lint -- --fix",
    "fix": "pnpm format && pnpm lint:fix",
    "up": "taze major -r -I"
  },
  "devDependencies": {
    "@arvinn/eslint-config": "^0.0.15",
    "@arvinn/prettier-config": "^0.0.13",
    "@arvinn/vscode-settings": "^0.0.3",
    "eslint": "^10.4.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.14.1",
    "turbo": "^2.9.15",
    "typescript": "~6"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "prettier": "@arvinn/prettier-config",
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged || true"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": "pnpm --filter web exec eslint --fix --no-warn-ignored",
    "packages/ui/**/*.{ts,tsx}": "pnpm --filter @workspace/ui exec eslint --fix --no-warn-ignored"
  }
}
